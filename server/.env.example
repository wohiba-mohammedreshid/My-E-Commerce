# Server environment variables — copy to .env and fill in values

PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Firebase Admin (optional — app runs in demo mode without this)
# Download serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Stripe payments (optional — demo mode processes orders without real charges)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Web Push notifications (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@shopease.com
