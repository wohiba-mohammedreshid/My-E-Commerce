# ===========================================
# ShopWave PWA - Environment Variables
# Copy this file to server/.env and client/.env
# ===========================================

# --- Firebase (get from Firebase Console > Project Settings) ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Client-side Firebase config (also set in client/.env)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- Stripe (test keys from dashboard.stripe.com) ---
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Web Push (generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@shopwave.com

# --- Server ---
PORT=5000
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@shopwave.com
